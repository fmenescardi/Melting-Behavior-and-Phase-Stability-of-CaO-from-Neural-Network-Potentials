# make CaO solid-liquid interface
atom_style      atomic
units           metal    # angstrom, eV, ps, bar
dimension       3
boundary        p p p

read_data       start.data
replicate       6 6 60 
displace_atoms  all random 0.1 0.1 0.1 377472 units box
velocity        all create 2500 87287 mom yes dist gaussian

# potential
pair_style   latte
pair_coeff * * ./lammps_weights

# simulation parameters
neighbor        1.0 bin
neigh_modify    every 1 check yes
timestep        0.0005 # ps

thermo          10
thermo_style    custom step temp pe etotal press lx ly lz

dump            1 all custom 10 make_interfase_123.dump id element x y z
dump_modify     1 element Ca O

# equilibrate at 3000 K
fix             1 all npt temp 3000 3000 0.050 iso 0.0 0.0 0.70 
run             5000
write_restart   CaO-3000K_1.restart
unfix           1

# create central liquid region
region          liquid block INF INF INF INF 72 218 units lattice 
group           liquid region liquid
velocity        liquid create 6000 89037 mom yes dist gaussian
fix             1 liquid nvt temp 6000 6000 0.05

run             10000
unfix           1
write_restart   two_phases_nvt_6000_2.restart

# bring liquid region at equilibrium temperature
fix		1 liquid npt temp 3000 3000 0.050 z 0.0 0.0 0.70
run		10000
unfix		1
write_restart   two_phases_npt_3.restart

